# === Supabase Database ===
# Transaction Mode (Porta 6543) - Usado pela aplicação para queries
DATABASE_URL="postgresql://postgres.[SEU_PROJECT_REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Session Mode (Porta 5432) - Usado pelo Prisma para rodar migrations
DIRECT_URL="postgresql://postgres.[SEU_PROJECT_REF]:[SENHA]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Conexão direta ao host (sem pooler) - Usado pelo PrismaFactory para schemas tenant dinâmicos
# Substitua [SEU_PROJECT_REF] pelo ref do projeto Supabase (ex: oxanubfolkoulklrhrpr)
DATABASE_URL_DIRECT="postgresql://postgres.[SEU_PROJECT_REF]:[SENHA]@db.[SEU_PROJECT_REF].supabase.co:5432/postgres"

# === Supabase API ===
SUPABASE_URL=https://[SEU_PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_chave_service_role_aqui

# === Servidor ===
PORT=3001
NODE_ENV=development

# === CORS ===
# Em produção, defina a URL do frontend separada por vírgula
# CORS_ORIGIN=https://vigiasaude.vercel.app,https://vigiasaude.com.br

# === JWT ===
JWT_SECRET=sua_chave_secreta_aqui
