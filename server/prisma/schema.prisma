// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COMPRADOR
  FORNECEDOR
}

enum PedidoStatus {
  RASCUNHO
  PENDENTE
  APROVADO
  EM_TRANSITO
  ENTREGUE
  CANCELADO
}

enum AtaStatus {
  ATIVA
  VENCIDA
  CANCELADA
  EM_REVISAO
  ESGOTADA
}

model CatmatMedicamento {
  id                 String   @id @default(uuid())
  codigoBr           String   @unique // Ex: BR027xxxx
  descricao          String
  unidadeFornecimento String
  criadoEm           DateTime @default(now())

  @@map("catmat_medicamentos")
}

model User {
  id           String      @id @default(uuid())
  nome         String
  email        String      @unique
  senhaHash    String
  role         Role        @default(COMPRADOR)
  fornecedorId String?
  criadoEm     DateTime    @default(now())
  atualizadoEm DateTime    @updatedAt
  auditorias   Auditoria[]

  @@map("usuarios")
}

model Ata {
  id                  String           @id @default(uuid())
  numero              String           @unique
  fornecedorNome      String           // Campo textual
  fornecedorCnpj      String?          // Campo textual
  processoLicitatorio String?
  numeroPregao        String?
  numeroEdital        String?
  vigenciaInicio      DateTime
  vigenciaFim         DateTime
  valorTeto           Decimal          @db.Decimal(12, 2)
  valorConsumido      Decimal          @default(0.00) @db.Decimal(12, 2)
  status              AtaStatus        @default(ATIVA)
  documentoPdfUrl     String?          // URL/Caminho local do arquivo
  observacoes         String?
  criadoEm            DateTime         @default(now())
  atualizadoEm        DateTime         @updatedAt
  
  medicamentos        MedicamentoAta[]
  pedidos             PedidoCompra[]
  consumos            AtaConsumo[]

  @@map("atas")
}

model MedicamentoAta {
  id                  String       @id @default(uuid())
  ataId               String
  ata                 Ata          @relation(fields: [ataId], references: [id], onDelete: Cascade)
  
  // Integração CATMAT
  catmatCodigo        String?
  nome                String
  unidadeFornecimento String?
  
  // Informados manualmente na ATA
  unidadeAta          String?
  marca               String?
  modelo              String?
  precoUnitario       Decimal      @db.Decimal(10, 2)
  qtdeInicial         Int
  
  // Saldos e Progressos reais (atualizados sob demanda/triggers)
  quantidadeUsada     Int          @default(0)
  saldoAtual          Int?         
  valorTotalItem      Decimal?     @db.Decimal(12, 2)
  
  precoBPS            Decimal?     @db.Decimal(10, 2)
  precoCMED           Decimal?     @db.Decimal(10, 2)
  
  observacoes         String?
  criadoEm            DateTime     @default(now())
  atualizadoEm        DateTime     @updatedAt @default(now())
  
  consumos            AtaConsumo[]

  @@map("medicamentos_ata")
}

model AtaConsumo {
  id                  String         @id @default(uuid())
  ataId               String
  ata                 Ata            @relation(fields: [ataId], references: [id], onDelete: Cascade)
  ataItemId           String
  ataItem             MedicamentoAta @relation(fields: [ataItemId], references: [id], onDelete: Cascade)
  pedidoId            String?        // Opcional (integração futura com módulo PedidoCompra)
  pedido              PedidoCompra?  @relation(fields: [pedidoId], references: [id])
  
  dataConsumo         DateTime       @default(now())
  quantidade          Int            
  valorUnitario       Decimal        @db.Decimal(10, 2)
  valorTotal          Decimal        @db.Decimal(12, 2)
  setorSolicitante    String?
  observacao          String?
  criadoEm            DateTime       @default(now())

  @@map("ata_consumos")
}

model PedidoCompra {
  id           String       @id @default(uuid())
  status       PedidoStatus @default(PENDENTE)
  ataId        String
  ata          Ata          @relation(fields: [ataId], references: [id])
  valorTotal   Decimal      @db.Decimal(12, 2)
  criadoEm     DateTime     @default(now())
  atualizadoEm DateTime     @updatedAt
  
  consumos     AtaConsumo[]

  @@index([ataId])
  @@index([status])
  @@map("pedidos_compra")
}

model Auditoria {
  id            String   @id @default(uuid())
  dataHora      DateTime @default(now())
  usuarioId     String
  usuario       User     @relation(fields: [usuarioId], references: [id])
  acao          String
  entidadeId    String
  dadosAntes    Json?
  dadosDepois   Json?
  justificativa String?

  @@index([usuarioId])
  @@index([dataHora])
  @@map("auditorias")
}
