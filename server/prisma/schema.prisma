// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COMPRADOR
  FORNECEDOR
}

enum PedidoStatus {
  RASCUNHO
  PENDENTE
  APROVADO
  EM_TRANSITO
  ENTREGUE
  CANCELADO
  ACEITO
  REJEITADO
}

enum AtaStatus {
  ATIVA
  VENCIDA
  CANCELADA
  EM_REVISAO
  ESGOTADA
}

model CatmatMedicamento {
  id                  String   @id @default(uuid())
  codigoBr            String   @unique @map("codigo_br") // Ex: BR027xxxx — índice único automático
  descricao           String
  unidadeFornecimento String   @map("unidade_fornecimento")
  criadoEm            DateTime @default(now()) @map("criado_em")

  @@map("catmat_medicamentos")
}

model Fornecedor {
  id            String   @id @default(uuid())
  cnpj          String   @unique
  razaoSocial   String   @map("razao_social")
  nomeFantasia  String   @map("nome_fantasia")
  email         String
  whatsapp      String
  status        String    @default("ATIVO")
  taxaAceitacao Decimal   @default(100.00) @db.Decimal(5, 2) @map("taxa_aceitacao")
  categorias    String[]
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @default(now()) @updatedAt @map("atualizado_em")
  deletedAt     DateTime? @map("deleted_at")

  // Relacionamentos
  usuarios      User[]
  atas          Ata[]    @relation("FornecedorAtas")
  pedidos       PedidoCompra[] @relation("FornecedorPedidos")

  @@map("fornecedores")
}



model User {
  id           String      @id @default(uuid())
  nome         String
  email        String      @unique
  senhaHash    String      @map("senha_hash")
  role         Role        @default(COMPRADOR)
  fornecedorId String?     @map("fornecedor_id")
  fornecedor   Fornecedor? @relation(fields: [fornecedorId], references: [id])
  criadoEm     DateTime    @default(now()) @map("criado_em")
  atualizadoEm DateTime    @updatedAt @map("atualizado_em")
  auditorias   Auditoria[]

  @@index([fornecedorId])
  @@map("usuarios")
}

model Ata {
  id                  String           @id @default(uuid())
  numero              String           @unique
  fornecedorNome      String           @map("fornecedor_nome") // Campo textual
  fornecedorCnpj      String?          @map("fornecedor_cnpj") // Campo textual
  fornecedor          Fornecedor?      @relation("FornecedorAtas", fields: [fornecedorCnpj], references: [cnpj])
  processoLicitatorio String?          @map("processo_licitatorio")
  numeroPregao        String?          @map("numero_pregao")
  numeroEdital        String?          @map("numero_edital")
  vigenciaInicio      DateTime         @map("vigencia_inicio")
  vigenciaFim         DateTime         @map("vigencia_fim")
  valorTeto           Decimal          @db.Decimal(12, 2) @map("valor_teto")
  valorConsumido      Decimal          @default(0.00) @db.Decimal(12, 2) @map("valor_consumido")
  status              AtaStatus        @default(ATIVA)
  documentoPdfUrl     String?          @map("documento_pdf_url")
  observacoes         String?
  criadoEm            DateTime         @default(now()) @map("criado_em")
  atualizadoEm        DateTime         @updatedAt @map("atualizado_em")
  deletedAt           DateTime?        @map("deleted_at")
  
  medicamentos        MedicamentoAta[]
  pedidos             PedidoCompra[]
  consumos            AtaConsumo[]

  @@index([fornecedorCnpj])
  @@map("atas")
}

model MedicamentoAta {
  id                  String       @id @default(uuid())
  ataId               String       @map("ata_id")
  ata                 Ata          @relation(fields: [ataId], references: [id], onDelete: Cascade)
  
  // Integração CATMAT
  catmatCodigo        String?      @map("catmat_codigo")
  nome                String
  unidadeFornecimento String?      @map("unidade_fornecimento")
  
  // Informados manualmente na ATA
  unidadeAta          String?      @map("unidade_ata")
  marca               String?
  modelo              String?
  precoUnitario       Decimal      @db.Decimal(10, 2) @map("preco_unitario")
  qtdeInicial         Int          @map("qtde_inicial")
  
  // Saldos e Progressos reais (atualizados sob demanda/triggers)
  quantidadeUsada     Int          @default(0) @map("quantidade_usada")
  saldoAtual          Int?         @map("saldo_atual")
  valorTotalItem      Decimal?     @db.Decimal(12, 2) @map("valor_total_item")
  
  precoBPS            Decimal?     @db.Decimal(10, 2) @map("preco_bps")
  precoCMED           Decimal?     @db.Decimal(10, 2) @map("preco_cmed")
  
  observacoes         String?
  criadoEm            DateTime     @default(now()) @map("criado_em")
  atualizadoEm        DateTime     @updatedAt @default(now()) @map("atualizado_em")
  
  consumos            AtaConsumo[]
  pedidoItens         PedidoCompraItem[]

  @@index([ataId])
  @@map("medicamentos_ata")
}

model AtaConsumo {
  id                  String         @id @default(uuid())
  ataId               String         @map("ata_id")
  ata                 Ata            @relation(fields: [ataId], references: [id], onDelete: Cascade)
  ataItemId           String         @map("ata_item_id")
  ataItem             MedicamentoAta @relation(fields: [ataItemId], references: [id], onDelete: Cascade)
  pedidoId            String?        @map("pedido_id") // Opcional (integração futura com módulo PedidoCompra)
  pedido              PedidoCompra?  @relation(fields: [pedidoId], references: [id])
  
  dataConsumo         DateTime       @default(now()) @map("data_consumo")
  quantidade          Int            
  valorUnitario       Decimal        @db.Decimal(10, 2) @map("valor_unitario")
  valorTotal          Decimal        @db.Decimal(12, 2) @map("valor_total")
  setorSolicitante    String?        @map("setor_solicitante")
  observacao          String?
  criadoEm            DateTime       @default(now()) @map("criado_em")

  @@index([ataId])
  @@index([ataItemId])
  @@index([pedidoId])
  @@map("ata_consumos")
}

model PedidoCompra {
  id              String             @id @default(uuid())
  numero          String             @unique
  status          PedidoStatus       @default(PENDENTE)
  ataId           String?            @map("ata_id")
  ata             Ata?               @relation(fields: [ataId], references: [id])
  fornecedorId    String?            @map("fornecedor_id")
  fornecedor      Fornecedor?        @relation("FornecedorPedidos", fields: [fornecedorId], references: [id])
  valorTotal      Decimal            @db.Decimal(12, 2) @map("valor_total")
  dataSolicitacao DateTime           @default(now()) @map("data_solicitacao")
  justificativa   String?
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")
  deletedAt       DateTime?          @map("deleted_at")
  consumos        AtaConsumo[]
  itens           PedidoCompraItem[]

  @@index([ataId])
  @@index([status])
  @@index([fornecedorId])
  @@map("pedidos_compra")
}

model PedidoCompraItem {
  id              String          @id @default(uuid())
  pedidoId        String          @map("pedido_id")
  pedido          PedidoCompra    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  medicamentoId   String?         @map("medicamento_id")
  medicamentoNome String          @map("medicamento_nome")
  quantidade      Int
  precoUnitario   Decimal         @db.Decimal(10, 2) @map("preco_unitario")
  valorTotal      Decimal         @db.Decimal(12, 2) @map("valor_total")
  ataItemId       String?         @map("ata_item_id")
  ataItem         MedicamentoAta? @relation(fields: [ataItemId], references: [id])
  criadoEm        DateTime        @default(now()) @map("criado_em")
  atualizadoEm    DateTime        @updatedAt        @default(now()) @map("atualizado_em")

  @@index([pedidoId])
  @@index([ataItemId])
  @@map("pedido_itens")
}

model Auditoria {
  id            String   @id @default(uuid())
  dataHora      DateTime @default(now()) @map("data_hora")
  usuarioId     String   @map("usuario_id")
  usuario       User     @relation(fields: [usuarioId], references: [id])
  acao          String
  entidadeId    String   @map("entidade_id")
  dadosAntes    Json?    @map("dados_antes")
  dadosDepois   Json?    @map("dados_depois")
  justificativa String?

  @@index([usuarioId])
  @@index([dataHora])
  @@map("auditorias")
}
