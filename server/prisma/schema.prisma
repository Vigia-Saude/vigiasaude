// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  COMPRADOR
  FORNECEDOR
}

enum Perfil {
  SECRETARIO_SAUDE
  GESTOR_ESTOQUE
  FARMACIA
  MEDICO
  ENTREGADOR
}

enum UsuarioStatus {
  PENDENTE
  ATIVO
  RECUSADO
  DESATIVADO
}

enum PedidoStatus {
  RASCUNHO
  PENDENTE
  APROVADO
  EM_TRANSITO
  ENTREGUE
  CANCELADO
  ACEITO
  REJEITADO
}

enum AtaStatus {
  ATIVA
  VENCIDA
  CANCELADA
  EM_REVISAO
  ESGOTADA
}

enum NotaFiscalStatus {
  PENDENTE
  CONFERIDA
  CONFERIDO_DIVERGENCIA
  CANCELADA
}

enum CdEstoqueLoteStatus {
  DISPONIVEL
  BLOQUEADO_RECALL
  ESGOTADO
  VENCIDO
}

enum AlertaCdTipo {
  DIVERGENCIA_NF
  RECALL
}

enum AlertaCdStatus {
  NOVO
  LIDO
  RESOLVIDO
}

model CatmatMedicamento {
  id                  String   @id @default(uuid())
  codigoBr            String   @unique @map("codigo_br") // Ex: BR027xxxx — índice único automático
  descricao           String
  unidadeFornecimento String   @map("unidade_fornecimento")
  criadoEm            DateTime @default(now()) @map("criado_em")

  @@map("catmat_medicamentos")
}

model Fornecedor {
  id            String   @id @default(uuid())
  cnpj          String   @unique
  razaoSocial   String   @map("razao_social")
  nomeFantasia  String   @map("nome_fantasia")
  email         String
  whatsapp      String
  status        String    @default("ATIVO")
  taxaAceitacao Decimal   @default(100.00) @db.Decimal(5, 2) @map("taxa_aceitacao")
  categorias    String[]
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @default(now()) @updatedAt @map("atualizado_em")
  deletedAt     DateTime? @map("deleted_at")

  // Relacionamentos
  usuarios      User[]
  atas          Ata[]         @relation("FornecedorAtas")
  pedidos       PedidoCompra[] @relation("FornecedorPedidos")
  notasFiscais  NotaFiscal[]

  @@map("fornecedores")
}



model User {
  id               String        @id @default(uuid())
  nome             String
  cpf              String?       @unique
  email            String?       @unique
  senhaHash        String        @map("senha_hash")
  role             Role          @default(COMPRADOR)
  perfil           Perfil?
  status           UsuarioStatus @default(PENDENTE)
  unidadeId        String?       @map("unidade_id")
  unidade          Unidade?      @relation(fields: [unidadeId], references: [id])
  tenantSchema     String?       @map("tenant_schema")
  permissoesExtras Json?         @map("permissoes_extras")
  justificativa    String?
  motivoRecusa     String?       @map("motivo_recusa")
  aprovadoPor      String?       @map("aprovado_por")
  aprovadoEm       DateTime?     @map("aprovado_em")
  fornecedorId     String?       @map("fornecedor_id")
  fornecedor       Fornecedor?   @relation(fields: [fornecedorId], references: [id])
  criadoEm         DateTime      @default(now()) @map("criado_em")
  atualizadoEm     DateTime      @updatedAt @map("atualizado_em")
  deletedAt        DateTime?     @map("deleted_at")
  auditorias       Auditoria[]
  pedidosSolicitados PedidoReposicao[] @relation("SolicitadoPor")
  pedidosEntregar    PedidoReposicao[] @relation("MotoristaPedidos")

  @@index([fornecedorId])
  @@index([status])
  @@map("usuarios")
}

model Ata {
  id                  String           @id @default(uuid())
  numero              String           @unique
  fornecedorNome      String           @map("fornecedor_nome") // Campo textual
  fornecedorCnpj      String?          @map("fornecedor_cnpj") // Campo textual
  fornecedor          Fornecedor?      @relation("FornecedorAtas", fields: [fornecedorCnpj], references: [cnpj])
  processoLicitatorio String?          @map("processo_licitatorio")
  numeroPregao        String?          @map("numero_pregao")
  numeroEdital        String?          @map("numero_edital")
  vigenciaInicio      DateTime         @map("vigencia_inicio")
  vigenciaFim         DateTime         @map("vigencia_fim")
  valorTeto           Decimal          @db.Decimal(12, 2) @map("valor_teto")
  valorConsumido      Decimal          @default(0.00) @db.Decimal(12, 2) @map("valor_consumido")
  status              AtaStatus        @default(ATIVA)
  documentoPdfUrl     String?          @map("documento_pdf_url")
  observacoes         String?
  criadoEm            DateTime         @default(now()) @map("criado_em")
  atualizadoEm        DateTime         @updatedAt @map("atualizado_em")
  deletedAt           DateTime?        @map("deleted_at")
  
  medicamentos        MedicamentoAta[]
  pedidos             PedidoCompra[]
  consumos            AtaConsumo[]

  @@index([fornecedorCnpj])
  @@map("atas")
}

model MedicamentoAta {
  id                  String       @id @default(uuid())
  ataId               String       @map("ata_id")
  ata                 Ata          @relation(fields: [ataId], references: [id], onDelete: Cascade)
  
  // Integração CATMAT
  catmatCodigo        String?      @map("catmat_codigo")
  nome                String
  unidadeFornecimento String?      @map("unidade_fornecimento")
  
  // Informados manualmente na ATA
  unidadeAta          String?      @map("unidade_ata")
  marca               String?
  modelo              String?
  precoUnitario       Decimal      @db.Decimal(10, 2) @map("preco_unitario")
  qtdeInicial         Int          @map("qtde_inicial")
  
  // Saldos e Progressos reais (atualizados sob demanda/triggers)
  quantidadeUsada     Int          @default(0) @map("quantidade_usada")
  saldoAtual          Int?         @map("saldo_atual")
  valorTotalItem      Decimal?     @db.Decimal(12, 2) @map("valor_total_item")
  
  precoBPS            Decimal?     @db.Decimal(10, 2) @map("preco_bps")
  precoCMED           Decimal?     @db.Decimal(10, 2) @map("preco_cmed")
  
  observacoes         String?
  criadoEm            DateTime     @default(now()) @map("criado_em")
  atualizadoEm        DateTime     @updatedAt @default(now()) @map("atualizado_em")
  
  consumos            AtaConsumo[]
  pedidoItens         PedidoCompraItem[]

  @@index([ataId])
  @@map("medicamentos_ata")
}

model AtaConsumo {
  id                  String         @id @default(uuid())
  ataId               String         @map("ata_id")
  ata                 Ata            @relation(fields: [ataId], references: [id], onDelete: Cascade)
  ataItemId           String         @map("ata_item_id")
  ataItem             MedicamentoAta @relation(fields: [ataItemId], references: [id], onDelete: Cascade)
  pedidoId            String?        @map("pedido_id") // Opcional (integração futura com módulo PedidoCompra)
  pedido              PedidoCompra?  @relation(fields: [pedidoId], references: [id])
  
  dataConsumo         DateTime       @default(now()) @map("data_consumo")
  quantidade          Int            
  valorUnitario       Decimal        @db.Decimal(10, 2) @map("valor_unitario")
  valorTotal          Decimal        @db.Decimal(12, 2) @map("valor_total")
  setorSolicitante    String?        @map("setor_solicitante")
  observacao          String?
  criadoEm            DateTime       @default(now()) @map("criado_em")

  @@index([ataId])
  @@index([ataItemId])
  @@index([pedidoId])
  @@map("ata_consumos")
}

model PedidoCompra {
  id              String             @id @default(uuid())
  numero          String             @unique
  status          PedidoStatus       @default(PENDENTE)
  ataId           String?            @map("ata_id")
  ata             Ata?               @relation(fields: [ataId], references: [id])
  fornecedorId    String?            @map("fornecedor_id")
  fornecedor      Fornecedor?        @relation("FornecedorPedidos", fields: [fornecedorId], references: [id])
  valorTotal      Decimal            @db.Decimal(12, 2) @map("valor_total")
  dataSolicitacao DateTime           @default(now()) @map("data_solicitacao")
  justificativa   String?
  criadoEm        DateTime           @default(now()) @map("criado_em")
  atualizadoEm    DateTime           @updatedAt @map("atualizado_em")
  deletedAt       DateTime?          @map("deleted_at")
  consumos        AtaConsumo[]
  itens           PedidoCompraItem[]
  notasFiscais    NotaFiscal[]

  @@index([ataId])
  @@index([status])
  @@index([fornecedorId])
  @@map("pedidos_compra")
}

model PedidoCompraItem {
  id              String          @id @default(uuid())
  pedidoId        String          @map("pedido_id")
  pedido          PedidoCompra    @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  medicamentoId   String?         @map("medicamento_id")
  medicamentoNome String          @map("medicamento_nome")
  quantidade      Int
  precoUnitario   Decimal         @db.Decimal(10, 2) @map("preco_unitario")
  valorTotal      Decimal         @db.Decimal(12, 2) @map("valor_total")
  ataItemId       String?         @map("ata_item_id")
  ataItem         MedicamentoAta? @relation(fields: [ataItemId], references: [id])
  criadoEm        DateTime        @default(now()) @map("criado_em")
  atualizadoEm    DateTime        @updatedAt        @default(now()) @map("atualizado_em")

  @@index([pedidoId])
  @@index([ataItemId])
  @@map("pedido_itens")
}

model Auditoria {
  id            String   @id @default(uuid())
  dataHora      DateTime @default(now()) @map("data_hora")
  usuarioId     String   @map("usuario_id")
  usuario       User     @relation(fields: [usuarioId], references: [id])
  acao          String
  entidadeId    String   @map("entidade_id")
  dadosAntes    Json?    @map("dados_antes")
  dadosDepois   Json?    @map("dados_depois")
  justificativa String?

  @@index([usuarioId])
  @@index([dataHora])
  @@map("auditorias")
}

// ─── Módulo Centro de Distribuição (CD) ──────────────────────────────────────

model NotaFiscal {
  id              String           @id @default(uuid())
  numeroNf        String           @map("numero_nf")
  serie           String
  chaveAcesso     String?          @unique @map("chave_acesso")
  dataEmissao     DateTime         @map("data_emissao")
  dataRecebimento DateTime?        @map("data_recebimento")
  fornecedorId    String           @map("fornecedor_id")
  fornecedor      Fornecedor       @relation(fields: [fornecedorId], references: [id])
  pedidoCompraId  String?          @map("pedido_compra_id")
  pedidoCompra    PedidoCompra?    @relation(fields: [pedidoCompraId], references: [id])
  status          NotaFiscalStatus @default(PENDENTE)
  valorTotal      Decimal          @db.Decimal(12, 2) @map("valor_total")
  xmlUrl          String?          @map("xml_url")
  observacoes     String?
  conferidoPor    String?          @map("conferido_por")
  conferidoEm     DateTime?        @map("conferido_em")
  criadoEm        DateTime         @default(now()) @map("criado_em")
  atualizadoEm    DateTime         @updatedAt @map("atualizado_em")
  deletedAt       DateTime?        @map("deleted_at")

  itens           NotaFiscalItem[]

  @@index([fornecedorId])
  @@index([pedidoCompraId])
  @@index([status])
  @@map("notas_fiscais")
}

model NotaFiscalItem {
  id                    String         @id @default(uuid())
  notaFiscalId          String         @map("nota_fiscal_id")
  notaFiscal            NotaFiscal     @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)
  catmatCodigo          String?        @map("catmat_codigo")
  medicamentoNome       String         @map("medicamento_nome")
  numeroLote            String         @map("numero_lote")
  dataValidade          DateTime       @db.Date @map("data_validade")
  quantidadeEsperada    Int            @map("quantidade_esperada")
  quantidadeRecebida    Int?           @map("quantidade_recebida")
  precoUnitario         Decimal        @db.Decimal(10, 2) @map("preco_unitario")
  divergencia           Boolean        @default(false)
  observacaoDivergencia String?        @map("observacao_divergencia")
  criadoEm              DateTime       @default(now()) @map("criado_em")

  estoqueLote           CdEstoqueLote?

  @@index([notaFiscalId])
  @@index([catmatCodigo])
  @@map("nota_fiscal_itens")
}

model CdEstoqueLote {
  id                String              @id @default(uuid())
  notaFiscalItemId  String              @unique @map("nota_fiscal_item_id")
  notaFiscalItem    NotaFiscalItem      @relation(fields: [notaFiscalItemId], references: [id])
  catmatCodigo      String?             @map("catmat_codigo")
  medicamentoNome   String              @map("medicamento_nome")
  numeroLote        String              @map("numero_lote")
  dataValidade      DateTime            @db.Date @map("data_validade")
  quantidadeInicial Int                 @map("quantidade_inicial")
  quantidadeAtual   Int                 @map("quantidade_atual")
  status            CdEstoqueLoteStatus @default(DISPONIVEL)
  criadoEm          DateTime            @default(now()) @map("criado_em")
  atualizadoEm      DateTime            @updatedAt @map("atualizado_em")
  deletedAt         DateTime?           @map("deleted_at")

  @@index([catmatCodigo, numeroLote])
  @@index([status])
  @@map("cd_estoque_lotes")
}

model Recall {
  id                 String    @id @default(uuid())
  catmatCodigo       String?   @map("catmat_codigo")
  numeroLote         String?   @map("numero_lote")
  motivo             String
  autoridadeEmissora String?   @map("autoridade_emissora")
  numeroAnvisa       String?   @map("numero_anvisa")
  dataEmissao        DateTime  @default(now()) @map("data_emissao")
  dataExpiracao      DateTime? @map("data_expiracao")
  ativo              Boolean   @default(true)
  criadoPor          String    @map("criado_por")
  criadoEm           DateTime  @default(now()) @map("criado_em")
  atualizadoEm       DateTime  @updatedAt @map("atualizado_em")

  @@index([catmatCodigo, numeroLote])
  @@index([ativo])
  @@map("recalls")
}

model AlertaCd {
  id                  String         @id @default(uuid())
  tipo                AlertaCdTipo
  referenciaId        String         @map("referencia_id")
  referenciaTipo      String         @map("referencia_tipo")
  titulo              String
  descricao           String
  status              AlertaCdStatus @default(NOVO)
  perfisDestinatarios String[]       @map("perfis_destinatarios")
  criadoEm            DateTime       @default(now()) @map("criado_em")
  lidoEm              DateTime?      @map("lido_em")
  lidoPor             String?        @map("lido_por")

  @@index([status])
  @@index([tipo])
  @@map("alertas_cd")
}

enum PedidoReposicaoStatus {
  PENDENTE
  EM_ANALISE
  EM_SEPARACAO
  AGUARDANDO_MOTORISTA
  EM_TRANSITO
  CONCLUIDO
  REJEITADO
}

enum PedidoReposicaoUrgencia {
  BAIXA
  MEDIA
  ALTA
}

model Unidade {
  id           String            @id @default(uuid())
  nome         String
  cnes         String?           @unique
  endereco     String?
  telefone     String?
  tenantSchema String            @unique @map("tenant_schema")
  ativa        Boolean           @default(true)
  criadoEm     DateTime          @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime          @default(now()) @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  deletedAt    DateTime?         @map("deleted_at") @db.Timestamptz(6)
  
  usuarios     User[]
  pedidos      PedidoReposicao[]

  @@map("unidades")
}

model PedidoReposicao {
  id              String                  @id @default(uuid())
  numero          String                  @unique // Ex: PED-2026-0001
  status          PedidoReposicaoStatus   @default(PENDENTE)
  urgencia        PedidoReposicaoUrgencia @default(BAIXA)
  unidadeId       String                  @map("unidade_id")
  unidade         Unidade                 @relation(fields: [unidadeId], references: [id])
  solicitadoPorId String                  @map("solicitado_por_id")
  solicitadoPor   User                    @relation("SolicitadoPor", fields: [solicitadoPorId], references: [id])
  
  motoristaId     String?                 @map("motorista_id")
  motorista       User?                   @relation("MotoristaPedidos", fields: [motoristaId], references: [id])
  
  justificativa   String?
  motivoRejeicao  String?                 @map("motivo_rejeicao")
  
  criadoEm        DateTime                @default(now()) @map("criado_em")
  atualizadoEm    DateTime                @updatedAt @map("atualizado_em")
  deletedAt       DateTime?               @map("deleted_at")
  
  itens           PedidoReposicaoItem[]

  @@index([unidadeId])
  @@index([status])
  @@index([motoristaId])
  @@map("pedidos_reposicao")
}

model PedidoReposicaoItem {
  id              String          @id @default(uuid())
  pedidoId        String          @map("pedido_id")
  pedido          PedidoReposicao @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  
  catmatCodigo    String?         @map("catmat_codigo")
  medicamentoNome String          @map("medicamento_nome")
  quantidade      Int
  
  criadoEm        DateTime        @default(now()) @map("criado_em")
  atualizadoEm    DateTime        @updatedAt @map("atualizado_em")

  @@index([pedidoId])
  @@index([catmatCodigo])
  @@map("pedido_reposicao_itens")
}

model PermissoesPerfil {
  id       String   @id @default(uuid())
  perfil   Perfil
  recurso  String
  acao     String
  criadoEm DateTime @default(now()) @map("criado_em")

  @@unique([perfil, recurso, acao])
  @@map("permissoes_perfil")
}
